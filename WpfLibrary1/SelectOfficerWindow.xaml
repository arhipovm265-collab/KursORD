<Window x:Class="WpfLibrary1.SelectOfficerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор сотрудника" Height="380" Width="640" WindowStartupLocation="CenterOwner" Background="#0B2545" Foreground="#FFFFFF"
        WindowState="Maximized" ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="AvailableGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150" />
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150" />
                <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="150" />
                <DataGridTextColumn Header="Отдел" Binding="{Binding Department.Name}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Width="160" MinHeight="32" Click="OnAssign">Добавить в отдел</Button>
            <Button Width="120" MinHeight="32" Margin="8,0,0,0" Click="OnCancel" Height="30">Отмена</Button>
        </StackPanel>
    </Grid>
</Window>