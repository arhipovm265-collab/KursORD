<Window x:Class="WpfLibrary1.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Первый запуск" Height="360" Width="480" WindowStartupLocation="CenterOwner" Background="#0B2545" Foreground="#FFFFFF">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="Имя пользователя:" Width="120" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" />
            <TextBox x:Name="UsernameBox" Width="240" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,6">
            <TextBlock Text="Пароль:" Width="120" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" />
            <PasswordBox x:Name="PasswordBox" Width="240" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,6">
            <TextBlock Text="Фамилия:" Width="120" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" />
            <TextBox x:Name="LastNameBox" Width="240" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,6">
            <TextBlock Text="Имя:" Width="120" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" />
            <TextBox x:Name="FirstNameBox" Width="240" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="4" VerticalAlignment="Top">
            <TextBlock Text="Отчество:" Width="120" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" />
            <TextBox x:Name="PatronymicBox" Width="240" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,8,0,0">
            <Button Width="190" Click="OnCreate" Height="27">Создать администратора</Button>
            <Button Width="120" Margin="8,0,0,0" Click="OnCancel" Height="34">Отмена</Button>
        </StackPanel>
    </Grid>
</Window>