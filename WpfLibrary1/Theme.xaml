<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBrush" Color="#0B2545"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#1E4A8A"/>
    <SolidColorBrush x:Key="AccentLight" Color="#3C6FB0"/>
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF"/>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,4,0,4"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#6B6B6B"/>
                <Setter Property="Foreground" Value="#E6E6E6"/>
                <Setter Property="Opacity" Value="0.9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="RowBackground" Value="#F7FBFF"/>
        <Setter Property="AlternatingRowBackground" Value="#EEF6FF"/>
        <Setter Property="Background" Value="#F4F9FF"/>
        <Setter Property="Foreground" Value="#0B2545"/>
        <Setter Property="Margin" Value="12"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="HeaderText">
        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="12,6,12,6"/>
    </Style>

</ResourceDictionary>