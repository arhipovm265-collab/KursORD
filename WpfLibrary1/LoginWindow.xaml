<Window x:Class="WpfLibrary1.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="220" Width="360" WindowStartupLocation="CenterScreen" Background="#0B2545" Foreground="#FFFFFF">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock Text="Имя пользователя" Foreground="#FFFFFF" FontWeight="Bold"/>
            <TextBox x:Name="UsernameBox"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,8,0,0">
            <TextBlock Text="Пароль" Foreground="#FFFFFF" FontWeight="Bold"/>
            <PasswordBox x:Name="PasswordBox"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="75" Click="OnLogin" Height="48">Войти</Button>
            <Button Width="75" Margin="8,0,0,0" Click="OnCancel" Height="48">Отмена</Button>
            <Button x:Name="FirstRunButton" Width="130" Margin="8,0,0,0" Click="OnFirstRun" Visibility="Collapsed" Height="48">Первый запуск</Button>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Grid.Row="3" Foreground="Red" TextWrapping="Wrap"/>
    </Grid>
</Window>