<Window x:Class="WpfLibrary1.AddDepartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить/Изменить отдел"
        Height="320" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#0B2545" Foreground="#FFFFFF"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Padding="16" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Добавить / Изменить отдел" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Grid.Row="0" Margin="0,0,0,12" />

            <!-- Fields grid: labels in column 0, inputs in column 1 -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" />
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" MinWidth="260" />

                <TextBlock Text="Улица:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,8,0,0" />
                <TextBox x:Name="StreetBox" Grid.Row="1" Grid.Column="1" MinWidth="260" Margin="0,8,0,0" />

                <TextBlock Text="Дом:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,8,0,0" />
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox x:Name="HouseBox" Width="120" />
                    <TextBlock Text="Город:" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" Margin="12,0,8,0" />
                    <TextBox x:Name="CityBox" Width="170" />
                </StackPanel>

                <TextBlock Text="Телефон:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,8,0,0" />
                <TextBox x:Name="PhoneBox" Grid.Row="3" Grid.Column="1" MinWidth="260" Margin="0,8,0,0" />

                <!-- ensure rows exist for the above placed controls -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Width="120" Click="OnSave" Height="30">Сохранить</Button>
                <Button Width="120" Margin="12,0,0,0" Click="OnCancel" Height="30">Отмена</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
