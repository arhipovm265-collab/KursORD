<Window x:Class="WpfLibrary1.DepartmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отделы" Height="500" Width="1348" WindowStartupLocation="CenterOwner" Background="#0B2545" Foreground="#FFFFFF"
        WindowState="Maximized" ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="DepartmentsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,12,0,12" Grid.ColumnSpan="3">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250" />
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0" Grid.Column="2" Width="734">
            <Button x:Name="AddDeptButton" Width="140" MinHeight="32" Margin="0,0,8,0" Click="OnAdd" Height="28">Добавить</Button>
            <Button x:Name="EditDeptButton" Width="140" MinHeight="32" Margin="0,0,8,0" Click="OnEdit" Height="25">Изменить</Button>
            <Button x:Name="DeleteDeptButton" Width="140" MinHeight="32" Margin="0,0,8,0" Click="OnDelete" Height="32">Удалить</Button>
            <Button x:Name="ViewDeptOfficersButton" Width="160" MinHeight="32" Margin="0,0,8,0" Click="OnViewOfficers" Height="27">Сотрудники отдела</Button>
            <!-- Добавление сотрудников перенесено в управление сотрудниками, кнопка удалена -->
            <Button Width="120" MinHeight="32" Click="OnClose">Готово</Button>
        </StackPanel>
    </Grid>
</Window>